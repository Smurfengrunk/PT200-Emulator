<Window x:Class="PT200Emulator.UI.MainWindow"
        xmlns:local="clr-namespace:PT200Emulator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PT200 Emulator" Height="600" Width="800"
        TextInput="Window_TextInput"
        Background="Black"
        KeyDown="Window_KeyDown"
        PreviewTextInput="Window_TextInput"
        Focusable="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <local:LogColorConverter x:Key="LogColorConverter"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Färgvalspanel -->
        <Border Background="DarkGray" Padding="5">
            <StackPanel DockPanel.Dock="Left" Width="120" Background="DarkGray">
                <TextBlock Text="Skärmtyp:" FontWeight="Bold" Margin="0,5,0,10"/>
                <Button x:Name="WhiteDisplay" Content="Vit" Click="SetWhiteDisplay" Margin="0,5,0,5" Focusable="False"/>
                <Button x:Name="BlueDisplay" Content="Blå" Click="SetBlueDisplay" Margin="0,5,0,5" Focusable="False"/>
                <Button x:Name="GreenDisplay" Content="Grön" Click="SetGreenDisplay" Margin="0,5,0,5" Focusable="False"/>
                <Button x:Name="AmberDisplay" Content="Amber" Click="SetAmberDisplay" Margin="0,5,0,5" Focusable="False"/>
                <Button x:Name="ColorDisplay" Content="Färg" Click="SetFullColorDisplay" Margin="0,5,0,5" Focusable="False"/>
                <Button x:Name="SendTestA" Content="Skicka test-A" Click="SendTestA_Click" Margin="0,5,0,5" Focusable="False" />
                <Button Content="Visa statustext" Click="ShowStatus_Click" Margin="0,5,0,5" Focusable="False" />
                <Button Content="Spara historik" Click="SaveStatusHistory_Click" Margin="0,5,0,5" Focusable="False"/>
                <Button Content="Toggle Console" Click="ToggleConsole_Click" Margin="0,5,0,20" Focusable="False"/>

                <TextBlock Text="Statushistorik:" FontWeight="Bold" Margin="0,5,0,4"/>
                <ListBox x:Name="StatusHistoryBox"
                    FontFamily="Consolas"
                    FontSize="11"
                    Foreground="Black"
                    Background="LightGray"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Height="120"
                    SelectionMode="Single"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                </ListBox>
            </StackPanel>
        </Border>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="200" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <!-- Terminalyta -->
            <Canvas x:Name="TerminalCanvas"
                Background="Black"
                Width="Auto"
                Height="Auto" />

            <!-- Statusrad -->
            <Grid Grid.Row="2" Background="{Binding ElementName=TerminalCanvas, Path=Background}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Name="StatusText"
                   Grid.Column="0"
                   Foreground="Black"
                   VerticalAlignment="Center"
                   Margin="10,0,0,0"
                   FontFamily="Consolas"
                   FontSize="12"/>

                <TextBlock Name="ClockTextBlock"
                   Grid.Column="1"
                   Foreground="Black"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"
                   FontFamily="Consolas"
                   FontSize="12"
                   HorizontalAlignment="Right"/>
            </Grid>
            <ListBox x:Name="InputTraceList"
                         Grid.Row="1"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="Black"
                         Foreground="LightGray"
                         Margin="10"
                         MaxHeight="200"
                         ItemsSource="{Binding TraceLog}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="{Binding Converter={StaticResource LogColorConverter}}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>
</Window>